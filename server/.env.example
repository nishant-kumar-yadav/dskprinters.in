# MongoDB connection string (MongoDB Atlas). If not set, an in-memory DB with seed data is used (dev only).
MONGO_URI=

# JWT secret for admin auth — generate with: openssl rand -base64 32
JWT_SECRET=

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=dsk@2025

# Cloudinary (image uploads). If not set, uploads fall back to inline data URLs (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

PORT=5000

# Nodemailer SMTP Configuration for Quotes
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@dskprinters.in

# Set on Render to enable keep-alive self-ping
RENDER_EXTERNAL_URL=
